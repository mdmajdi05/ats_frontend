# ─────────────────────────────────────────────────────────────
# AeroTurbineSpare — Frontend Environment Variables
# Copy to .env.local and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── Mock Mode (no backend needed) ──
#   NEXT_PUBLIC_USE_MOCK=true
#   NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── Local Backend ──
#   NEXT_PUBLIC_USE_MOCK=false
#   NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── Live Backend ──
#   NEXT_PUBLIC_USE_MOCK=false
#   NEXT_PUBLIC_API_URL=https://api.aeroturbinespare.com/api/v1

# ───────────────────────────────────
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Optional: site URL for canonical links / OG metadata
NEXT_PUBLIC_SITE_URL=https://aeroturbinespare.com
